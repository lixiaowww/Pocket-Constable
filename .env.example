# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# LICENSE_SECRET: Secret seed for cryptographically signing/verifying Shortcuts license activation keys
# ⚠️ REQUIRED — Must be a high-entropy random string. Server will refuse to start without it.
LICENSE_SECRET="<请设置一个高强度随机字符串，至少32位>"

# ADMIN_PASSCODE: Access password for the merchant admin panel dashboard
# ⚠️ REQUIRED — Must be a strong password (12+ characters). Server will refuse to start without it.
ADMIN_PASSCODE="<请设置管理员密码，至少12位含大小写数字>"

# ALLOWED_ORIGINS: Comma-separated list of allowed CORS origins.
# Leave empty for development (allows all). Set in production for security.
# Example: ALLOWED_ORIGINS="https://pocket-constable.vercel.app,https://yourdomain.com"
ALLOWED_ORIGINS=""

# KV_REST_API_URL / KV_REST_API_TOKEN: Upstash Redis for persistent data storage.
# Optional — falls back to in-memory storage if not provided (data lost on cold start).
KV_REST_API_URL=""
KV_REST_API_TOKEN=""
